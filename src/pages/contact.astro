---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Schedule an Inspection | Vantage Point" description="Schedule a thermal solar inspection. Tell us about your site and we'll get back to you within 24 hours.">
  <!-- Page Hero -->
  <section class="py-32 pt-40">
    <div class="section-container">
      <div class="text-center">
        <div class="inline-block mb-6">
          <span class="text-xs font-bold tracking-widest text-amber-500">CONTACT US</span>
        </div>
        <h1 class="heading-display mb-6">Schedule an Inspection</h1>
        <p class="text-lg text-zinc-300 max-w-2xl mx-auto">
          Tell us about your solar installation and we'll get back to you within 24 hours.
        </p>
      </div>
    </div>
  </section>

  <!-- Two-column layout -->
  <section class="py-20 pb-32">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- LEFT - Contact Form -->
        <div class="lg:col-span-2">
          <form
            id="contactForm"
            action="https://formsubmit.co/dan@hithisisdan.com"
            method="POST"
            class="space-y-6"
          >
            <!-- FormSubmit config -->
            <input type="hidden" name="_subject" value="New Inspection Request from Vantage Point" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="" />
            <input type="text" name="_honey" style="display:none" />

            <!-- Name -->
            <div>
              <label for="name" class="block text-sm uppercase tracking-wider text-zinc-400 mb-2">
                Name <span class="text-amber-500">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your full name"
                class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-amber-500 transition-colors"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm uppercase tracking-wider text-zinc-400 mb-2">
                Email <span class="text-amber-500">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="your@email.com"
                class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-amber-500 transition-colors"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="phone" class="block text-sm uppercase tracking-wider text-zinc-400 mb-2">
                Phone
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="(555) 000-0000"
                class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-amber-500 transition-colors"
              />
            </div>

            <!-- Company -->
            <div>
              <label for="company" class="block text-sm uppercase tracking-wider text-zinc-400 mb-2">
                Company
              </label>
              <input
                type="text"
                id="company"
                name="company"
                placeholder="Your company name"
                class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-amber-500 transition-colors"
              />
            </div>

            <!-- Installation Type -->
            <div>
              <label for="installationType" class="block text-sm uppercase tracking-wider text-zinc-400 mb-2">
                Installation Type
              </label>
              <select
                id="installationType"
                name="installationType"
                class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 text-white focus:outline-none focus:border-amber-500 transition-colors cursor-pointer"
              >
                <option value="">Select type...</option>
                <option value="commercial-rooftop">Commercial Rooftop</option>
                <option value="carport">Carport / Canopy</option>
                <option value="ground-mount">Ground Mount</option>
                <option value="utility-scale">Utility Scale</option>
                <option value="industrial">Industrial / Other</option>
              </select>
            </div>

            <!-- Site Location -->
            <div>
              <label for="location" class="block text-sm uppercase tracking-wider text-zinc-400 mb-2">
                Site Location <span class="text-amber-500">*</span>
              </label>
              <input
                type="text"
                id="location"
                name="location"
                required
                placeholder="City, state or address"
                class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-amber-500 transition-colors"
              />
            </div>

            <!-- Approximate System Size -->
            <div>
              <label for="systemSize" class="block text-sm uppercase tracking-wider text-zinc-400 mb-2">
                Approximate System Size
              </label>
              <input
                type="text"
                id="systemSize"
                name="systemSize"
                placeholder="e.g. 500kW, 2MW, 10,000 panels"
                class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-amber-500 transition-colors"
              />
            </div>

            <!-- Details -->
            <div>
              <label for="details" class="block text-sm uppercase tracking-wider text-zinc-400 mb-2">
                Anything Else We Should Know
              </label>
              <textarea
                id="details"
                name="details"
                rows="4"
                placeholder="Known issues, timeline, specific concerns..."
                class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-amber-500 transition-colors resize-none"
              ></textarea>
            </div>

            <!-- Submit -->
            <div class="pt-4">
              <button
                type="submit"
                class="btn-primary w-full"
              >
                Request Inspection
              </button>
            </div>
          </form>
        </div>

        <!-- RIGHT - Sidebar -->
        <div class="lg:col-span-1 space-y-8">
          <!-- Contact Info -->
          <div class="card">
            <h3 class="heading-card mb-6">Get in Touch</h3>
            <div class="space-y-4">
              <div>
                <p class="text-xs uppercase tracking-wider text-zinc-500 mb-1">Location</p>
                <p class="text-white">Southern California</p>
              </div>
              <div>
                <p class="text-xs uppercase tracking-wider text-zinc-500 mb-1">Response Time</p>
                <p class="text-white">Within 24 hours</p>
              </div>
              <div class="pt-4 border-t border-zinc-800">
                <p class="text-xs uppercase tracking-wider text-zinc-500 mb-2">Or email directly</p>
                <a href="mailto:dan@hithisisdan.com" class="text-amber-500 hover:text-amber-400 font-medium transition-colors">
                  dan@hithisisdan.com
                </a>
              </div>
            </div>
          </div>

          <!-- What to Expect -->
          <div class="card">
            <h3 class="heading-card mb-6">What Happens Next</h3>
            <div class="space-y-4">
              <div class="flex gap-3">
                <div class="flex-shrink-0">
                  <div class="flex items-center justify-center h-8 w-8 rounded-full bg-amber-500/20 border border-amber-500">
                    <span class="text-amber-500 font-bold text-sm">1</span>
                  </div>
                </div>
                <p class="text-white font-medium text-sm">Tell us about your site</p>
              </div>
              <div class="flex gap-3">
                <div class="flex-shrink-0">
                  <div class="flex items-center justify-center h-8 w-8 rounded-full bg-amber-500/20 border border-amber-500">
                    <span class="text-amber-500 font-bold text-sm">2</span>
                  </div>
                </div>
                <p class="text-white font-medium text-sm">We follow up within 24 hours</p>
              </div>
              <div class="flex gap-3">
                <div class="flex-shrink-0">
                  <div class="flex items-center justify-center h-8 w-8 rounded-full bg-amber-500/20 border border-amber-500">
                    <span class="text-amber-500 font-bold text-sm">3</span>
                  </div>
                </div>
                <p class="text-white font-medium text-sm">Schedule the inspection</p>
              </div>
              <div class="flex gap-3">
                <div class="flex-shrink-0">
                  <div class="flex items-center justify-center h-8 w-8 rounded-full bg-amber-500/20 border border-amber-500">
                    <span class="text-amber-500 font-bold text-sm">4</span>
                  </div>
                </div>
                <p class="text-white font-medium text-sm">Receive your report</p>
              </div>
            </div>
          </div>

          <!-- Trust -->
          <div class="card">
            <h3 class="heading-card mb-6">Why Trust Us</h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3 pb-3 border-b border-zinc-800">
                <div class="w-2 h-2 bg-amber-500 rounded-full flex-shrink-0"></div>
                <span class="text-white text-sm">FAA Part 107 Licensed</span>
              </div>
              <div class="flex items-center gap-3 pb-3 border-b border-zinc-800">
                <div class="w-2 h-2 bg-amber-500 rounded-full flex-shrink-0"></div>
                <span class="text-white text-sm">$1M Liability Insurance</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 bg-amber-500 rounded-full flex-shrink-0"></div>
                <span class="text-white text-sm">Thermal + RGB Sensors</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 border-t border-zinc-800">
    <div class="section-container">
      <div class="max-w-3xl mx-auto">
        <h2 class="heading-section text-center mb-12">Common Questions</h2>

        <div class="space-y-0 border border-zinc-800">
          <details class="group border-b border-zinc-800 last:border-b-0">
            <summary class="flex items-center justify-between cursor-pointer py-4 px-6 hover:bg-zinc-900/50 transition-colors select-none">
              <span class="text-white font-medium group-open:text-amber-500 transition-colors">How long does an inspection take?</span>
              <span class="text-amber-500 text-xl group-open:rotate-180 transition-transform">&#8250;</span>
            </summary>
            <div class="px-6 pb-4 text-zinc-300">
              <p>Most commercial installations take half a day on site. You'll receive the full report within a few business days after the flight.</p>
            </div>
          </details>

          <details class="group border-b border-zinc-800 last:border-b-0">
            <summary class="flex items-center justify-between cursor-pointer py-4 px-6 hover:bg-zinc-900/50 transition-colors select-none">
              <span class="text-white font-medium group-open:text-amber-500 transition-colors">Does the system need to be running during inspection?</span>
              <span class="text-amber-500 text-xl group-open:rotate-180 transition-transform">&#8250;</span>
            </summary>
            <div class="px-6 pb-4 text-zinc-300">
              <p>Yes. Thermal inspection requires the panels to be under load and generating power. We fly during peak irradiance hours for the best results.</p>
            </div>
          </details>

          <details class="group border-b border-zinc-800 last:border-b-0">
            <summary class="flex items-center justify-between cursor-pointer py-4 px-6 hover:bg-zinc-900/50 transition-colors select-none">
              <span class="text-white font-medium group-open:text-amber-500 transition-colors">What areas do you serve?</span>
              <span class="text-amber-500 text-xl group-open:rotate-180 transition-transform">&#8250;</span>
            </summary>
            <div class="px-6 pb-4 text-zinc-300">
              <p>Based in Southern California. We can travel for larger installations — reach out and we'll work out the logistics.</p>
            </div>
          </details>

          <details class="group border-b border-zinc-800 last:border-b-0">
            <summary class="flex items-center justify-between cursor-pointer py-4 px-6 hover:bg-zinc-900/50 transition-colors select-none">
              <span class="text-white font-medium group-open:text-amber-500 transition-colors">What do I get in the report?</span>
              <span class="text-amber-500 text-xl group-open:rotate-180 transition-transform">&#8250;</span>
            </summary>
            <div class="px-6 pb-4 text-zinc-300">
              <p>Full thermal orthomosaic, GPS-tagged defect catalog with severity classification, high-resolution aerial photos, and an executive summary with recommended actions.</p>
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between cursor-pointer py-4 px-6 hover:bg-zinc-900/50 transition-colors select-none">
              <span class="text-white font-medium group-open:text-amber-500 transition-colors">Do I need to be on-site during the flight?</span>
              <span class="text-amber-500 text-xl group-open:rotate-180 transition-transform">&#8250;</span>
            </summary>
            <div class="px-6 pb-4 text-zinc-300">
              <p>Not necessarily. We just need site access and any relevant safety protocols. But if you want to be there, you're welcome to.</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </section>
</Layout>
