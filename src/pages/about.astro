---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Vantage Point" description="FAA Part 107 certified drone pilot specializing in thermal solar inspection. Learn about our equipment, process, and what drives us.">
  <!-- Page Hero -->
  <section class="py-32 pt-40">
    <div class="section-container">
      <div class="text-center space-y-6">
        <div class="inline-block">
          <span class="text-amber-500 text-sm font-semibold tracking-widest">ABOUT US</span>
        </div>
        <h1 class="heading-display">Aerial Thermal Inspection, Done Right</h1>
        <p class="text-zinc-300 text-lg max-w-2xl mx-auto">
          One operator, one focus: delivering clear, accurate thermal data for commercial solar installations across Southern California.
        </p>
      </div>
    </div>
  </section>

  <!-- About / Story Section -->
  <section class="py-20 border-t border-zinc-800">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-6">
          <h2 class="heading-section">The Pilot Behind the Data</h2>
          <div class="space-y-4 text-zinc-400 leading-relaxed">
            <p>
              I'm Dan, an FAA Part 107 certified commercial drone pilot based in Southern California. I specialize in aerial thermal inspection for commercial solar installations — identifying performance issues that aren't visible from the ground and delivering data that maintenance teams can act on directly.
            </p>
            <p>
              Vantage Point started from a simple observation: the gap between noticing a production dip and pinpointing the cause is often months of guesswork. A calibrated thermal scan closes that gap in a single session. That's the service I built the company around.
            </p>
            <div class="pt-4 border-l-2 border-amber-500 pl-6">
              <p class="text-white font-semibold italic">
                "We provide the data. You make the decisions."
              </p>
            </div>
          </div>
        </div>

        <div>
          <div class="rounded-lg overflow-hidden">
            <img src="/images/solar-rgb/carport-street.jpg" alt="Aerial view of solar panel installation - the kind of site we inspect" class="w-full h-auto" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Equipment Section -->
  <section class="py-20 border-t border-zinc-800">
    <div class="section-container">
      <h2 class="heading-section mb-12">Our Equipment</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Thermal Sensor -->
        <div class="card">
          <div class="flex justify-center mb-6">
            <svg class="w-10 h-10 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </div>
          <h3 class="heading-card text-center mb-4">Radiometric Thermal Sensor</h3>
          <ul class="space-y-3 text-sm text-zinc-400">
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">&#8226;</span>
              <span>Calibrated thermal imaging camera</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">&#8226;</span>
              <span>Per-pixel temperature measurement</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">&#8226;</span>
              <span>Detects sub-degree temperature anomalies</span>
            </li>
          </ul>
        </div>

        <!-- RGB Camera -->
        <div class="card">
          <div class="flex justify-center mb-6">
            <svg class="w-10 h-10 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="heading-card text-center mb-4">High-Resolution RGB</h3>
          <ul class="space-y-3 text-sm text-zinc-400">
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">&#8226;</span>
              <span>20MP+ aerial camera</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">&#8226;</span>
              <span>4K video capability</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">&#8226;</span>
              <span>Visual documentation of physical damage</span>
            </li>
          </ul>
        </div>

        <!-- Processing -->
        <div class="card">
          <div class="flex justify-center mb-6">
            <svg class="w-10 h-10 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="heading-card text-center mb-4">Analysis & Reporting</h3>
          <ul class="space-y-3 text-sm text-zinc-400">
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">&#8226;</span>
              <span>Thermal orthomosaic stitching</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">&#8226;</span>
              <span>Anomaly detection and classification</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">&#8226;</span>
              <span>GPS-tagged defect reports</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 border-t border-zinc-800">
    <div class="section-container">
      <h2 class="heading-section mb-12 text-center">Certified & Insured</h2>

      <div class="max-w-3xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="bg-vp-surface rounded-lg p-6 flex flex-col items-center justify-center text-center space-y-3">
            <svg class="w-8 h-8 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="text-white font-semibold text-sm">FAA Part 107</p>
              <p class="text-zinc-500 text-xs">Certified Pilot</p>
            </div>
          </div>

          <div class="bg-vp-surface rounded-lg p-6 flex flex-col items-center justify-center text-center space-y-3">
            <svg class="w-8 h-8 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="text-white font-semibold text-sm">$1M Liability</p>
              <p class="text-zinc-500 text-xs">Insurance Coverage</p>
            </div>
          </div>

          <div class="bg-vp-surface rounded-lg p-6 flex flex-col items-center justify-center text-center space-y-3">
            <svg class="w-8 h-8 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="text-white font-semibold text-sm">Thermal + RGB</p>
              <p class="text-zinc-500 text-xs">Dual Sensor System</p>
            </div>
          </div>

          <div class="bg-vp-surface rounded-lg p-6 flex flex-col items-center justify-center text-center space-y-3">
            <svg class="w-8 h-8 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="text-white font-semibold text-sm">IEC 62446-3</p>
              <p class="text-zinc-500 text-xs">Standards Aware</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-zinc-800">
    <div class="section-container">
      <div class="max-w-2xl mx-auto text-center space-y-8">
        <h2 class="heading-section">Let's Talk About Your Installation</h2>
        <p class="text-zinc-400 text-lg">
          Whether you're managing a single rooftop or a multi-site portfolio, we can scope an inspection that fits your needs.
        </p>
        <div>
          <a href="/contact" class="btn-primary inline-block">
            Schedule an Inspection
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
