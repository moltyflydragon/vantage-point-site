---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';


interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Survey-grade aerial data capture for construction, solar, roofing, agriculture, and mining. RTK-enabled drone services in Southern California.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vantage Point" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Botpress Web Chat -->
    <script is:inline src="https://cdn.botpress.cloud/webchat/v3.6/inject.js"></script>
    <script is:inline src="https://files.bpcontent.cloud/2026/02/12/03/20260212032115-JF4HORWO.js" defer></script>

    <style is:inline>
      /* ===== Vantage Point Chatbot Theme ===== */

      /* Hide the default floating FAB button */
      .bpFab,
      .bpModalButton,
      [class*="FabButton"],
      [class*="fab-button"] {
        display: none !important;
      }

      /* Container: fixed bar above footer area */
      #vp-chat-wrapper {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 40;
        display: flex;
        flex-direction: column;
        align-items: center;
        pointer-events: none;
      }

      /* Collapsed state: search-bar style */
      #vp-chat-bar {
        width: 100%;
        max-width: 640px;
        margin: 0 auto 1.25rem;
        pointer-events: auto;
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      }

      #vp-chat-bar.expanded {
        max-width: 640px;
        margin-bottom: 0;
      }

      /* The input bar */
      #vp-chat-input-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #18181b;
        border: 1px solid #3f3f46;
        border-radius: 1rem;
        padding: 0.875rem 1.25rem;
        cursor: text;
        transition: all 0.3s ease;
        box-shadow: 0 4px 24px rgba(0,0,0,0.5);
      }

      #vp-chat-input-row:hover,
      #vp-chat-input-row:focus-within {
        border-color: rgba(245, 158, 11, 0.5);
        box-shadow: 0 4px 24px rgba(0,0,0,0.5), 0 0 0 1px rgba(245, 158, 11, 0.15);
      }

      #vp-chat-input-row svg {
        flex-shrink: 0;
        color: #a1a1aa;
        transition: color 0.2s;
      }

      #vp-chat-input-row:focus-within svg {
        color: #f59e0b;
      }

      #vp-chat-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #fafafa;
        font-family: 'Inter', sans-serif;
        font-size: 0.9375rem;
        line-height: 1.5;
      }

      #vp-chat-input::placeholder {
        color: #71717a;
      }

      #vp-chat-send {
        flex-shrink: 0;
        background: #f59e0b;
        border: none;
        border-radius: 0.5rem;
        width: 2.25rem;
        height: 2.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        opacity: 0;
        transform: scale(0.8);
        pointer-events: none;
      }

      #vp-chat-send.visible {
        opacity: 1;
        transform: scale(1);
        pointer-events: auto;
      }

      #vp-chat-send:hover {
        background: #d97706;
      }

      #vp-chat-send svg {
        color: #09090b;
        width: 16px;
        height: 16px;
      }

      /* Expanded conversation area */
      #vp-chat-messages {
        display: none;
        flex-direction: column;
        gap: 0.75rem;
        max-height: 400px;
        overflow-y: auto;
        padding: 1.25rem;
        background: #09090b;
        border: 1px solid #3f3f46;
        border-bottom: none;
        border-radius: 1rem 1rem 0 0;
        box-shadow: 0 -4px 24px rgba(0,0,0,0.4);
        scrollbar-width: thin;
        scrollbar-color: #3f3f46 transparent;
      }

      #vp-chat-messages::-webkit-scrollbar {
        width: 4px;
      }
      #vp-chat-messages::-webkit-scrollbar-track {
        background: transparent;
      }
      #vp-chat-messages::-webkit-scrollbar-thumb {
        background: #3f3f46;
        border-radius: 2px;
      }

      #vp-chat-bar.expanded #vp-chat-messages {
        display: flex;
      }

      #vp-chat-bar.expanded #vp-chat-input-row {
        border-radius: 0 0 1rem 1rem;
        border-top-color: #27272a;
      }

      /* Message bubbles */
      .vp-msg {
        max-width: 85%;
        padding: 0.625rem 1rem;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        line-height: 1.55;
        font-family: 'Inter', sans-serif;
        animation: vp-fade-in 0.25s ease-out;
      }

      .vp-msg-user {
        align-self: flex-end;
        background: #f59e0b;
        color: #09090b;
        border-bottom-right-radius: 0.25rem;
      }

      .vp-msg-bot {
        align-self: flex-start;
        background: #18181b;
        color: #e4e4e7;
        border: 1px solid #27272a;
        border-bottom-left-radius: 0.25rem;
      }

      /* Typing indicator */
      .vp-typing {
        display: flex;
        gap: 4px;
        padding: 0.75rem 1rem;
        align-self: flex-start;
      }
      .vp-typing span {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #71717a;
        animation: vp-bounce 1.2s infinite;
      }
      .vp-typing span:nth-child(2) { animation-delay: 0.15s; }
      .vp-typing span:nth-child(3) { animation-delay: 0.3s; }

      /* Close button */
      #vp-chat-close {
        display: none;
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        background: none;
        border: none;
        color: #71717a;
        cursor: pointer;
        padding: 0.25rem;
        transition: color 0.2s;
        z-index: 2;
      }
      #vp-chat-close:hover { color: #fafafa; }
      #vp-chat-bar.expanded #vp-chat-close { display: block; }

      /* Label */
      #vp-chat-label {
        text-align: center;
        color: #52525b;
        font-size: 0.6875rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        font-family: 'Inter', sans-serif;
        transition: opacity 0.3s;
      }
      #vp-chat-bar.expanded #vp-chat-label { opacity: 0; height: 0; margin: 0; overflow: hidden; }

      @keyframes vp-fade-in {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes vp-bounce {
        0%, 60%, 100% { transform: translateY(0); }
        30% { transform: translateY(-4px); }
      }

      /* Mobile adjustments */
      @media (max-width: 680px) {
        #vp-chat-bar {
          margin-left: 0.75rem;
          margin-right: 0.75rem;
        }
        #vp-chat-bar.expanded {
          margin-left: 0;
          margin-right: 0;
          max-width: 100%;
        }
        #vp-chat-bar.expanded #vp-chat-messages {
          border-radius: 0;
          max-height: 50vh;
        }
        #vp-chat-bar.expanded #vp-chat-input-row {
          border-radius: 0;
        }
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Custom Chat Widget -->
    <div id="vp-chat-wrapper">
      <div id="vp-chat-bar">
        <div id="vp-chat-label">Ask about our drone services</div>
        <div style="position:relative;">
          <button id="vp-chat-close" aria-label="Close chat">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
          <div id="vp-chat-messages"></div>
          <div id="vp-chat-input-row">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <input id="vp-chat-input" type="text" placeholder="How can we help with your project?" autocomplete="off" />
            <button id="vp-chat-send">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
    (function() {
      var bar = document.getElementById('vp-chat-bar');
      var input = document.getElementById('vp-chat-input');
      var sendBtn = document.getElementById('vp-chat-send');
      var closeBtn = document.getElementById('vp-chat-close');
      var messages = document.getElementById('vp-chat-messages');
      var expanded = false;
      var conversationId = null;

      // Show/hide send button based on input
      input.addEventListener('input', function() {
        sendBtn.classList.toggle('visible', input.value.trim().length > 0);
      });

      function expand() {
        if (!expanded) {
          bar.classList.add('expanded');
          expanded = true;
        }
      }

      function collapse() {
        bar.classList.remove('expanded');
        expanded = false;
      }

      function addMessage(text, sender) {
        var div = document.createElement('div');
        div.className = 'vp-msg ' + (sender === 'user' ? 'vp-msg-user' : 'vp-msg-bot');
        div.textContent = text;
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
      }

      function showTyping() {
        var div = document.createElement('div');
        div.className = 'vp-typing';
        div.id = 'vp-typing-indicator';
        div.innerHTML = '<span></span><span></span><span></span>';
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
      }

      function hideTyping() {
        var el = document.getElementById('vp-typing-indicator');
        if (el) el.remove();
      }

      function sendMessage() {
        var text = input.value.trim();
        if (!text) return;

        expand();
        addMessage(text, 'user');
        input.value = '';
        sendBtn.classList.remove('visible');
        showTyping();

        // Send to Botpress webchat via postMessage
        if (window.botpress) {
          window.botpress.sendMessage(text);
        }
      }

      // Listen for bot responses
      if (window.botpress) {
        window.botpress.on('message', function(msg) {
          if (msg.type === 'text' && msg.payload && msg.payload.text) {
            hideTyping();
            addMessage(msg.payload.text, 'bot');
          }
        });
      }

      // Fallback: poll for botpress ready
      var checkBp = setInterval(function() {
        if (window.botpress) {
          clearInterval(checkBp);
          window.botpress.on('message', function(msg) {
            if (msg.type === 'text' && msg.payload && msg.payload.text) {
              hideTyping();
              addMessage(msg.payload.text, 'bot');
            }
          });
        }
      }, 500);

      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') sendMessage();
      });
      sendBtn.addEventListener('click', sendMessage);
      closeBtn.addEventListener('click', collapse);

      // Focus input on click anywhere on bar
      document.getElementById('vp-chat-input-row').addEventListener('click', function() {
        input.focus();
      });
    })();
    </script>
  </body>
</html>
