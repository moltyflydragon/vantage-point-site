---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-zinc-800 bg-vp-bg">
  <div class="section-container py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-4">
          <svg
            width="28"
            height="28"
            viewBox="0 0 32 32"
            class="text-amber-500"
          >
            <path
              d="M6 24L16 8l10 16"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <circle cx="16" cy="12" r="2" fill="currentColor"></circle>
          </svg>
          <span
            class="text-white font-black text-base uppercase tracking-widest"
          >
            Vantage Point
          </span>
        </a>
        <p class="text-zinc-500 text-sm leading-relaxed">
          Aerial thermal solar inspection. We find the problems your array is hiding.
          Serving Southern California.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4
          class="text-xs uppercase tracking-widest text-zinc-400 font-semibold mb-4"
        >
          Services
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="/services"
              class="text-sm text-zinc-500 hover:text-amber-500 transition-colors"
            >
              Thermal Solar Inspection
            </a>
          </li>
          <li>
            <a
              href="/services"
              class="text-sm text-zinc-500 hover:text-amber-500 transition-colors"
            >
              Defect Mapping
            </a>
          </li>
          <li>
            <a
              href="/services"
              class="text-sm text-zinc-500 hover:text-amber-500 transition-colors"
            >
              Aerial Documentation
            </a>
          </li>
          <li>
            <a
              href="/services"
              class="text-sm text-zinc-500 hover:text-amber-500 transition-colors"
            >
              Industrial Inspection
            </a>
          </li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4
          class="text-xs uppercase tracking-widest text-zinc-400 font-semibold mb-4"
        >
          Company
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="/work"
              class="text-sm text-zinc-500 hover:text-amber-500 transition-colors"
            >
              Our Work
            </a>
          </li>
          <li>
            <a
              href="/about"
              class="text-sm text-zinc-500 hover:text-amber-500 transition-colors"
            >
              About
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="text-sm text-zinc-500 hover:text-amber-500 transition-colors"
            >
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4
          class="text-xs uppercase tracking-widest text-zinc-400 font-semibold mb-4"
        >
          Contact
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="/contact"
              class="text-sm text-zinc-500 hover:text-amber-500 transition-colors"
            >
              Schedule an Inspection
            </a>
          </li>
          <li>
            <span class="text-sm text-zinc-500">Southern California</span>
          </li>
          <li>
            <span class="text-sm text-zinc-500">FAA Part 107 Licensed</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-12 pt-8 border-t border-zinc-800/50 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-xs text-zinc-600">
        &copy; {currentYear} Vantage Point. All rights reserved.
      </p>
      <p class="text-xs text-zinc-600">
        FAA Part 107 Certified &middot; Fully Insured &middot; Southern
        California
      </p>
    </div>
  </div>
</footer>
